{
  "name": "uniscept-app",
  "version": "0.14.0",
  "private": true,
  "description": "Uniscept — a tool that structures complex thinking and discussions into a clear logical system.",
  "homepage": "https://github.com/arsen-sharifov/uniscept-app#readme",
  "author": {
    "name": "Arsen Sharifov"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "dev:full": "supabase start && next dev",
    "build": "next build",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "lint": "eslint --fix --cache --cache-location node_modules/.cache/eslint/ --max-warnings=0",
    "lint:check": "eslint --cache --cache-location node_modules/.cache/eslint/ --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm type-check && pnpm lint:check && pnpm format:check",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "clean": "node -e \"['.next','node_modules','storybook-static','.cache'].forEach(p=>require('fs').rmSync(p,{recursive:true,force:true}))\""
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "*.{json,css,md,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zundo": "^2.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-storybook": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.1",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
